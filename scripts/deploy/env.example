# Pizzini relay environment file.
#
# At deploy time this is rendered (with real APNs identifiers + .p8
# path) to /etc/pizzini-relay/env, mode 0600, owner root:root —
# systemd reads it as PID 1 and exports the values into the relay's
# environment before dropping privileges, so the relay user does not
# need read access to the file itself.
#
# Anything redacted here stays redacted in version control; the real
# values only live on the production box.


# ---- APNs (Apple Push Notification service) ----
# Path to the .p8 auth key issued by Apple. Owned root:pizzini-relay,
# mode 0640 (the relay reads it via group, can't write it).
APNS_AUTH_KEY_PATH=/etc/pizzini-relay/apns-auth.p8

# 10-character Apple developer Team ID. Not secret — embedded in
# every signed iOS app. Find it in App Store Connect → Membership.
APNS_TEAM_ID=XXXXXXXXXX

# 10-character APNs Key ID. Not secret. Find it on the same page
# in Apple Developer where the .p8 was issued (Keys section).
APNS_KEY_ID=XXXXXXXXXX

# Which APNs server the relay forwards push notifications to.
#   sandbox    → api.sandbox.push.apple.com   (Xcode debug builds)
#   production → api.push.apple.com           (TestFlight / App Store)
# Same .p8 works for both — the choice is purely which endpoint to call.
APNS_ENDPOINT=sandbox

# Defaults to com.bytepotato.pizzini. Override only if the iOS
# bundle id changes.
# APNS_TOPIC=com.bytepotato.pizzini


# ---- Relay runtime ----
# Persistent state directory (encrypted push-token store + key file).
# systemd's StateDirectory= creates and owns this at start; the
# relay only needs PIZZINI_RELAY_STATE_DIR pointed at it.
PIZZINI_RELAY_STATE_DIR=/var/lib/pizzini-relay

# DO NOT SET PIZZINI_RELAY_BIND in production. The binary's default
# is 127.0.0.1:7777, which is what the systemd-sandboxed service
# wants and what /etc/tor/torrc.d/pizzini.conf forwards the .onion
# to. Setting this to anything non-loopback would expose the relay
# on the public internet and defeat the whole onion-only design.

# Connection cap defaults to 4096. The systemd unit's
# LimitNOFILE=16384 gives 3:1 fd headroom; raise this only after
# raising LimitNOFILE in lockstep.
# PIZZINI_RELAY_MAX_CONNS=4096
