# macOS
.DS_Store

# Xcode — user-specific state
xcuserdata/
*.xcuserstate
*.xcuserdatad/
DerivedData/
build/
*.ipa
*.dSYM
*.dSYM.zip

# Swift Package Manager — keep Package.resolved when the local package has
# external deps; nothing pinned today.
.swiftpm/
.build/
Package.resolved

# Rust
target/
*.rs.bk
*.pdb

# Generated FFI artifacts.
# crypto-core/include/pizzini_crypto_core.h is committed; cbindgen regenerates it
# on each build. CI should fail if the working tree differs after `cargo build`.
*.xcframework/

# Editors
.idea/
.vscode/
*.swp
*.swo

# Secrets — never commit. F-NEW-1002: extra specificity to defeat
# accidental `git add -f` autocomplete on common secret filename
# shapes. AuthKey_*.p8 (APNs auth keys) and assorted private-key
# variants get explicit names so even a wildcard-disabling shell
# alias can't slip them through.
*.p12
*.p8
*.mobileprovision
*.cer
*.pem
AuthKey_*.p8
AuthKey_*
*_secret.*
*_credential.*
*credentials*
.env
.env.*
!.env.example

# Relay persistent state — encrypted push-token store + sibling key file.
# Default location written by the relay process is the working directory;
# operators with a different `PIZZINI_RELAY_STATE_DIR` should keep their
# state outside the repo, but the default path is excluded here as a
# belt-and-braces guard against an accidental `git add .`.
pizzini-relay-state/

# Local-only audit / security-review notes. Internal documents that
# describe vulnerabilities, untested-claims, or per-surface findings
# must never land in the public repo — keep them out of version
# control entirely.
.audit-*/

# Operator transparency-log signing keys + the signed log file. The
# signing key MUST NEVER enter the repo; the published log is hosted
# elsewhere (GitHub Pages / IPFS / a static site), not in the source
# tree. Leaving local-only copies excluded.
operator-keys/
transparency-log.ndjson
