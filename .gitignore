# macOS
.DS_Store

# Xcode — user-specific state
xcuserdata/
*.xcuserstate
*.xcuserdatad/
DerivedData/
build/
*.ipa
*.dSYM
*.dSYM.zip

# Swift Package Manager — keep Package.resolved when the local package has
# external deps; nothing pinned today.
.swiftpm/
.build/
Package.resolved

# Rust
target/
*.rs.bk
*.pdb
# `cargo vendor --locked vendor > .cargo/config-vendor.toml` is run by
# scripts/build-relay-release.sh inside a Docker-driven reproducible
# build. The whole `.cargo/` directory is local build state — config
# files generated by `cargo vendor` AND the `.global-cache` /
# `.package-cache` / `.package-cache-mutate` lock files cargo writes
# when it uses `/work/.cargo` as CARGO_HOME inside the container.
# All local-only, none should ship in the tree.
.cargo/
vendor/

# Generated FFI artifacts.
# crypto-core/include/pizzini_crypto_core.h is committed; cbindgen regenerates it
# on each build. CI should fail if the working tree differs after `cargo build`.
*.xcframework/

# Staged tor C headers — populated by `scripts/build-tor-xcframework.sh`.
# Kept out of the repo because (a) it's ~3 MB of vendored upstream
# headers and (b) the headers must stay in lockstep with the pinned
# Tor.xcframework artifact, which the build script enforces.
swift/Sources/PizziniTorObjC/torheaders/

# Editors
.idea/
.vscode/
*.swp
*.swo

# Secrets — never commit. F-NEW-1002: extra specificity to defeat
# accidental `git add -f` autocomplete on common secret filename
# shapes. AuthKey_*.p8 (APNs auth keys) and assorted private-key
# variants get explicit names so even a wildcard-disabling shell
# alias can't slip them through.
*.p12
*.p8
*.mobileprovision
*.cer
*.pem
AuthKey_*.p8
AuthKey_*
*_secret.*
*_credential.*
*credentials*
.env
.env.*
!.env.example

# Relay persistent state — encrypted push-token store + sibling key file.
# Default location written by the relay process is the working directory;
# operators with a different `PIZZINI_RELAY_STATE_DIR` should keep their
# state outside the repo, but the default path is excluded here as a
# belt-and-braces guard against an accidental `git add .`.
pizzini-relay-state/

# Local-only audit / security-review notes. Internal documents that
# describe vulnerabilities, untested-claims, or per-surface findings
# must never land in the public repo — keep them out of version
# control entirely.
.audit-*/

# Operator transparency-log signing key. The signing key MUST NEVER
# enter the repo — leaks invalidate every published attestation.
# `transparency-log.ndjson` itself IS published in this repo (operator
# chose repo over GitHub Pages / IPFS for hosting), so it is NOT
# gitignored — see scripts/sign-transparency-entry.sh.
operator-keys/
operator-key.pem
operator-key*.pem
!operator-key.pub.pem

# Per-deploy throwaway helper at the repo root (a copy of the
# /tmp/sign-this-deploy.sh template with paths/SHAs filled in for
# one specific release). Stays out of the repo because it has a
# path to the operator's signing key baked in.
/sign.sh

# Tor v3 onion-service directories. The directory name is the .onion
# address itself, and the directory contains `hs_ed25519_secret_key`
# — the private key that proves ownership of the onion. Committing
# this would let anyone impersonate the relay. We exclude the whole
# folder shape regardless of where in the tree it lands.
*.onion/
*.onion

# Rendered (not template) relay env file with real APNs Team/Key IDs
# pointing at the .p8 path. Stays out of the repo even when copied
# locally for staging.
scripts/deploy/env
scripts/deploy/env.rendered
